# Google OAuth (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# App URL (local / production)
AUTH_URL=http://localhost:3000

# Set to true to print detailed Auth.js / adapter errors in the terminal
AUTH_DEBUG=false

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Use the legacy service_role JWT (eyJ...) for @auth/supabase-adapter
SUPABASE_SERVICE_ROLE_KEY=

# Optional: lock the app to your Google account
ALLOWED_EMAIL=

# Optional: sync only children of this Drive folder (instead of Drive root)
DRIVE_ROOT_FOLDER_ID=

# Optional: max upload size in MB (default 500)
MAX_UPLOAD_MB=500
